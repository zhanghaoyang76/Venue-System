/**
 * 后端 API 根路径（与 server 默认端口 3000 一致）。
 * - 微信开发者工具：可用 http://127.0.0.1:3000/api
 * - 真机预览：改为电脑局域网 IP，如 http://192.168.1.3:3000/api，并关闭域名校验或配置合法域名
 */
export const API_BASE = 'http://127.0.0.1:3000/api'

/** 与 server/.env 中 MOCK_AUTH、ADMIN_OPENID 对应 */
export const MOCK_OPENID_USER = 'student_demo'
export const MOCK_OPENID_ADMIN = 'oAdminDev001'
