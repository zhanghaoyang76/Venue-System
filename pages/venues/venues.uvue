		flex: 1;
		font-size: 14px;
		color: #1d1d1f;
	}

	.type-row {
		flex-direction: row;
		flex-wrap: wrap;
		margin-bottom: 14px;
	}

	.type-chip {
		background-color: #ffffff;
		border-radius: 999px;
		padding: 8px 12px;
		margin-right: 8px;
		margin-bottom: 8px;
		border-width: 1px;
		border-style: solid;
		border-color: #e0e0e0;
	}

	.type-active {
		background-color: #0066cc;
		border-color: #0066cc;
	}

	.type-text {
		font-size: 13px;
		color: #1d1d1f;
	}

	.type-active-text {
		color: #ffffff;
	}

	.venue-list {
		flex-direction: column;
	}

	.venue-card {
		flex-direction: row;
		background-color: #ffffff;
