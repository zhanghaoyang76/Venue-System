<template>
	<view class="page">
		<view class="header">
			<view class="header-copy">
				<text class="title">我的提醒</text>
				<text class="subtitle">预约提交、审核结果和开场提醒。</text>
			</view>
			<text class="mark-all-btn" @click="markAllAsRead">全部已读</text>
		</view>

		<view v-if="unreadCount > 0" class="summary">
			<text class="summary-num">{{ unreadCount }}</text>
			<text class="summary-text">条未读提醒</text>
		</view>

		<view v-if="notifications.length === 0" class="empty">
			<text class="empty-text">暂无提醒</text>
			<text class="empty-sub">所有预约提醒都会显示在这里。</text>
		</view>

		<view v-else class="notification-list">
			<view 
				v-for="item in notifications" 
				:key="item.id"
				:class="['notification-item', { 'unread': !item.isRead }]"
				@click="markAsRead(item)"
			>
				<view class="notification-header">
					<text class="notification-title">{{ item.title }}</text>
					<text v-if="!item.isRead" class="unread-badge">新</text>
				</view>
				<text class="notification-content">{{ item.content }}</text>
				<view v-if="item.venueName" class="notification-details">
					<text class="detail-item">{{ item.venueName }}</text>
					<text v-if="item.date" class="detail-item">{{ item.date }} {{ item.timeSlot }}</text>
				</view>
				<text class="notification-time">{{ formatTime(item.createdAt) }}</text>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
	import { onLoad, onShow } from '@dcloudio/uni-app'
	import { apiGetNotifications, apiMarkNotificationAsRead, apiMarkAllNotificationsAsRead, apiGetUnreadNotificationCount, type NotificationItem } from '../../common/api.uts'

	const notifications = ref<NotificationItem[]>([])
	const unreadCount = ref(0)

	onLoad(() => {
		loadNotifications()
	})

	onShow(() => {
		loadUnreadCount()
	})

	async function loadNotifications(): Promise<void> {
		try {
			const list = await apiGetNotifications()
			notifications.value = list
		} catch (e) {
			uni.showToast({ title: '加载提醒失败', icon: 'none' })
		}
	}

	async function loadUnreadCount(): Promise<void> {
		try {
			const count = await apiGetUnreadNotificationCount()
			unreadCount.value = count
		} catch (e) {
		}
	}

	async function markAsRead(item: NotificationItem): Promise<void> {
		if (item.isRead) return

		try {
			await apiMarkNotificationAsRead(item.id)
			item.isRead = true
			unreadCount.value = Math.max(0, unreadCount.value - 1)
		} catch (e) {
			uni.showToast({ title: '标记已读失败', icon: 'none' })
		}
	}

	async function markAllAsRead(): Promise<void> {
		if (unreadCount.value === 0) return

		try {
			await apiMarkAllNotificationsAsRead()
			notifications.value = notifications.value.map(item => ({
				...item,
				isRead: true
			}))
			unreadCount.value = 0
			uni.showToast({ title: '已全部标记为已读', icon: 'success' })
		} catch (e) {
			uni.showToast({ title: '操作失败', icon: 'none' })
		}
	}

	function formatTime(timeStr: string): string {
		try {
			const date = new Date(timeStr)
			const now = new Date()
			const diff = now.getTime() - date.getTime()
			
			if (diff < 24 * 60 * 60 * 1000) {
				if (diff < 60 * 60 * 1000) {
					const mins = Math.floor(diff / (60 * 1000))
					return mins <= 0 ? '刚刚' : `${mins} 分钟前`
				}
				const hours = Math.floor(diff / (60 * 60 * 1000))
				return `${hours} 小时前`
			}
			
			if (diff < 48 * 60 * 60 * 1000) {
				return '昨天'
			}
			
			return timeStr.slice(0, 10)
		} catch (e) {
			return timeStr.slice(0, 10)
		}
	}
</script>

