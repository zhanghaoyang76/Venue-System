		font-size: 15px;
		color: #6e6e73;
	}

	.empty {
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 60px 20px;
		background-color: #ffffff;
		border-radius: 18px;
		border-width: 1px;
		border-style: solid;
		border-color: #e0e0e0;
	}

	.empty-text {
		font-size: 17px;
