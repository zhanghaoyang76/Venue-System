		line-height: 25px;
	}

	.choice {
		flex-direction: column;
		background-color: #ffffff;
		border-radius: 18px;
		padding: 24px;
		margin-bottom: 14px;
		border-width: 1px;
		border-style: solid;
		border-color: #e0e0e0;
	}

	.user-choice {
		border-color: #d2d2d7;
	}

	.admin-choice {
		border-color: #d2d2d7;
	}

	.choice-badge {
		align-self: flex-start;
		font-size: 14px;
		color: #0066cc;
		background-color: #f5f5f7;
		padding: 7px 14px;
		border-radius: 999px;
		font-weight: 400;
		margin-bottom: 14px;
	}

	.admin-badge {
		color: #0066cc;
		background-color: #f5f5f7;
	}

	.choice-title {
		font-size: 22px;
		font-weight: 600;
		color: #1d1d1f;
		margin-bottom: 8px;
	}

	.choice-desc {
		font-size: 15px;
