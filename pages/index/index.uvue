		flex-direction: column;
	}

	.card {
		flex-direction: row;
		align-items: center;
		background-color: #ffffff;
		border-radius: 18px;
		padding: 18px;
		margin-bottom: 12px;
		border-left-width: 0;
		border-left-style: solid;
		border-width: 1px;
		border-style: solid;
		border-color: #e0e0e0;
	}

