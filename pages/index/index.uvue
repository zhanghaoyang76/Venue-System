<template>
	<view class="page">
		<view class="hero">
			<view class="hero-top">
				<view class="hero-titles">
					<text class="hero-title">校园场地预约</text>
					<text class="hero-sub">学生与教师使用 · 选择场地并发起预约</text>
				</view>
				<view class="hero-actions">
					<view class="notification-badge" @click="goNotifications" v-if="unreadCount > 0">
						<text class="badge-text">{{ unreadCount }}</text>
					</view>
					<text class="hero-link" @click="goProfile">我的</text>
				</view>
			</view>
		</view>

		<view class="grid">
			<view
				v-for="item in VENUE_LIST"
				:key="item.id"
				class="card"
				:style="{ borderLeftColor: item.accent }"
				@click="openBooking(item.id)"
			>
				<text class="card-emoji">{{ item.emoji }}</text>
				<view class="card-body">
					<text class="card-title">{{ item.name }}</text>
					<text class="card-desc">{{ item.desc }}</text>
				</view>
				<text class="card-arrow">›</text>
			</view>
		</view>

		<view class="footer-hint">
			<text class="hint-text">预约记录与资料在「我的」；需切换身份请在我的页选择退出</text>
		</view>

		<view class="back-section">
			<button class="back-btn" type="default" @click="backToEntry">返回学生/教师入口</button>
			<text class="back-tips">返回登录页面重新选择身份</text>
		</view>
	</view>
</template>

<script setup lang="uts">
	import { onShow, onLoad } from '@dcloudio/uni-app'
	import { VENUE_LIST } from '../../common/venues.uts'
	import { getCurrentRole, ROLE_USER, clearAdminAuth } from '../../common/role.uts'
	import { getToken, clearAuth, apiGetUnreadNotificationCount } from '../../common/api.uts'

	const unreadCount = ref(0)

	onLoad(() => {
		loadUnreadCount()
	})

	onShow(() => {
		if (getToken().length == 0 || getCurrentRole() != ROLE_USER) {
			uni.reLaunch({ url: '/pages/entry/entry' })
		}
		loadUnreadCount()
	})

	function openBooking(venueId: string): void {
		uni.navigateTo({
			url: '/pages/booking/booking?venueId=' + venueId,
		})
	}

	function goProfile(): void {
		uni.navigateTo({
			url: '/pages/profile/profile',
		})
	}

	function backToEntry(): void {
		// 清除所有认证状态
		clearAuth()
		clearAdminAuth()
		uni.reLaunch({ url: '/pages/entry/entry' })
	}

	async function loadUnreadCount(): Promise<void> {
		try {
			const count = await apiGetUnreadNotificationCount()
			unreadCount.value = count
		} catch (e) {
			// 忽略错误，不影响主要功能
		}
	}

	function goNotifications(): void {
		uni.navigateTo({
			url: '/pages/notifications/notifications',
		})
	}
</script>

