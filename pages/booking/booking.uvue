		margin-bottom: 16px;
		border-width: 1px;
		border-style: solid;
		border-color: #e0e0e0;
	}

	.bad-text {
		font-size: 14px;
		color: #6e6e73;
		text-align: center;
		line-height: 22px;
		margin-bottom: 16px;
	}

	.bad-btn {
		min-width: 120px;
	}

	.head {
		flex-direction: row;
		align-items: center;
		background-color: #ffffff;
		border-radius: 18px;
		padding: 20px;
		margin-bottom: 22px;
		border-width: 1px;
		border-style: solid;
		border-color: #e0e0e0;
	}

