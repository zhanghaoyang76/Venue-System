		font-size: 40px;
		margin-right: 12px;
	}

	.head-text {
		flex: 1;
		flex-direction: column;
	}

	.title {
		font-size: 22px;
		font-weight: 600;
		color: #1d1d1f;
		margin-bottom: 6px;
	}

	.sub {
		font-size: 15px;
		color: #6e6e73;
		line-height: 22px;
	}

	.section {
		flex-direction: column;
		margin-bottom: 16px;
	}

	.label {
		font-size: 14px;
		color: #1d1d1f;
		margin-bottom: 8px;
		font-weight: 600;
	}

	.picker-box {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		background-color: #ffffff;
		border-radius: 14px;
		padding: 14px 16px;
		border-width: 1px;
		border-style: solid;
		border-color: #d2d2d7;
	}

	.picker-val {
		font-size: 16px;
		color: #1d1d1f;
	}

	.picker-tip {
		font-size: 13px;
		color: #86868b;
	}

	.court-type-selector {
		flex-direction: row;
		margin-top: 8px;
	}

	.court-type-option {
		flex: 1;
		padding: 12px 16px;
		background-color: #ffffff;
		border-radius: 999px;
		margin-right: 8px;
		align-items: center;
		justify-content: center;
		border-width: 1px;
		border-style: solid;
		border-color: #d2d2d7;
	}

	.court-type-option:last-child {
		margin-right: 0;
	}

	.court-type-option.active {
		background-color: #0066cc;
		border-color: #0066cc;
	}

	.court-type-option.active .option-text {
		color: #ffffff;
	}

	.option-text {
		font-size: 14px;
		font-weight: 400;
		color: #1d1d1f;
	}

	.duration-selector {
		flex-direction: row;
		flex-wrap: wrap;
		margin-top: 8px;
	}

	.duration-option {
		padding: 10px 14px;
		background-color: #ffffff;
		border-radius: 999px;
		margin-right: 8px;
		margin-bottom: 8px;
		align-items: center;
		justify-content: center;
		border-width: 1px;
		border-style: solid;
		border-color: #d2d2d7;
	}

	.duration-option.active {
		background-color: #0066cc;
		border-color: #0066cc;
	}

	.duration-option.active .option-text {
		color: #ffffff;
	}

	.textarea {
		background-color: #ffffff;
		border-radius: 14px;
		padding: 14px 16px;
		min-height: 88px;
		font-size: 15px;
		color: #1d1d1f;
