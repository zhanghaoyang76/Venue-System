PORT=3000
JWT_SECRET=please-change-to-a-long-random-string
MOCK_AUTH=1
WX_APPID=
WX_SECRET=
ADMIN_OPENID=oAdminDev001

# MySQL 8（Windows 服务名常为 MySQL80，与下面「库名」不是一回事）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=你的密码
# 数据表会建在该库下；不存在则启动时自动 CREATE DATABASE
MYSQL_DATABASE=venue_booking
